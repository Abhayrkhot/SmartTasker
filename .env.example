# Copy to `.env` in the repo root before `docker compose up`. Never commit real secrets.

# Django (EC2 / Docker: keep DEBUG false; set a strong SECRET_KEY)
SECRET_KEY=your_secret
DJANGO_DEBUG=False

# PostgreSQL — Django database connection (Compose service name is `db`)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Same values for the Postgres container (must match DB_* above)
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional
POSTGRES_PORT=5432
WEB_PORT=8000
