# Copy to `.env` in the repo root (or `backend/.env`). Never commit real secrets.

# --- Django (production) ---
# Use a long random string. Either SECRET_KEY or DJANGO_SECRET_KEY is accepted by settings.py.
SECRET_KEY=your-long-random-secret
# DJANGO_SECRET_KEY=your-long-random-secret

# false = production (default). For local runserver without Docker: true
DJANGO_DEBUG=False

# * = allow any Host header (demo/EC2). For stricter production, use: api.example.com,your-ec2-ip
DJANGO_ALLOWED_HOSTS=*

# --- PostgreSQL (Django reads these; Docker Compose also uses POSTGRES_* for the db service) ---
DB_NAME=smarttasker
DB_USER=smarttasker
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432

POSTGRES_DB=smarttasker
POSTGRES_USER=smarttasker
POSTGRES_PASSWORD=change-this-password

# --- Docker Compose only ---
POSTGRES_PORT=5432
WEB_PORT=8000

# --- JWT (optional) ---
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
