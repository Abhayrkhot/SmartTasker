# Copy to `.env` in the repo root (or `backend/.env`). Never commit real secrets.

# Django
DJANGO_SECRET_KEY=your-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-public-dns

# PostgreSQL — preferred variable names for Django (backend/backend/settings.py)
DB_NAME=smarttasker
DB_USER=smarttasker
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432

# Legacy/alternate names (also supported; Docker Compose maps these for the DB service)
POSTGRES_DB=smarttasker
POSTGRES_USER=smarttasker
POSTGRES_PASSWORD=change-this-password

# Docker Compose only (host port mapping)
POSTGRES_PORT=5432
WEB_PORT=8000

# JWT lifetimes (optional)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
