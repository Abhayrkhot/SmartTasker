# Copy to .env and adjust for local Docker or EC2 deployment

DJANGO_SECRET_KEY=your-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-public-dns

POSTGRES_DB=smarttasker
